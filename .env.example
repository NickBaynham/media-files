# Copy to .env and fill in real values. Never commit .env.
# cp .env.example .env

# --- Required ---
# AWS credentials (use IAM user or temporary credentials from STS).
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# Region where the bucket lives or will be created.
AWS_DEFAULT_REGION=us-east-1
# Globally unique bucket name (lowercase, 3–63 chars; see README).
S3_BUCKET_NAME=your-unique-media-bucket-name

# --- Optional ---
# Session token when using temporary credentials (e.g. assumed role).
# AWS_SESSION_TOKEN=

# Object key prefix inside the bucket (no leading slash; trailing slash optional).
# Example: media/v1/
S3_KEY_PREFIX=

# Legacy alias: if S3_KEY_PREFIX is unset, this is used as the key prefix.
# S3_BUCKET_PREFIX=

# S3 storage class: STANDARD, STANDARD_IA, INTELLIGENT_TIERING, GLACIER_IR, etc.
S3_STORAGE_CLASS=STANDARD

# Object ACL (omit for default private / bucket-owner-enforced).
# Do not set to public-read unless you intend public objects.
# S3_ACL=private

# If true, print actions without calling AWS (upload/delete).
DRY_RUN=false

# Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
